# =============================================================================
# Mycosoft Environment Configuration
# Copy this file to .env.local and fill in your values
# =============================================================================

# -----------------------------------------------------------------------------
# Core Application
# -----------------------------------------------------------------------------
NODE_ENV=production
NEXT_PUBLIC_BASE_URL=http://localhost:3000
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:3000/api

# -----------------------------------------------------------------------------
# Database (PostgreSQL via Supabase or direct)
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql://mycosoft:password@localhost:5432/mycosoft
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# -----------------------------------------------------------------------------
# Redis
# -----------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379

# -----------------------------------------------------------------------------
# Authentication
# -----------------------------------------------------------------------------
NEXTAUTH_SECRET=your-nextauth-secret
NEXTAUTH_URL=http://localhost:3000
GITHUB_ID=
GITHUB_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# -----------------------------------------------------------------------------
# AI / LLM Services
# -----------------------------------------------------------------------------
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_AI_API_KEY=
GROQ_API_KEY=
XAI_API_KEY=

# -----------------------------------------------------------------------------
# NVIDIA Nemotron (Myca's primary LLM brain)
# -----------------------------------------------------------------------------
# Option 1: NVIDIA NIM Cloud API (fastest, no local GPU needed)
# Sign up at https://build.nvidia.com → API Catalog → get API key (free 1000 req/day)
NVIDIA_NIM_API_KEY=
NVIDIA_NIM_API_URL=https://integrate.api.nvidia.com/v1
NVIDIA_NIM_MODEL=nvidia/llama-3.1-nemotron-70b-instruct

# Option 2: Local Ollama (runs on MAS VM or GPU cluster)
# CPU-only VM: use gemma2:2b or phi3:mini (no GPU needed, fast)
# GPU cluster: use nemotron:70b or llama3.1:70b
OLLAMA_BASE_URL=http://192.168.0.188:11434
OLLAMA_MODEL=gemma2:2b
OLLAMA_CPU_MODEL=gemma2:2b

# Option 3: NemoClaw Gateway (Jetson/on-premise GPU node)
# For field deployments (Mushroom 1, Hyphae 1 mobile data centers)
NEMOCLAW_GATEWAY_URL=http://192.168.0.123:18789

# -----------------------------------------------------------------------------
# MAS (Multi-Agent System) Orchestrator
# -----------------------------------------------------------------------------
MAS_API_URL=http://192.168.0.188:8001
MAS_API_KEY=
NEXT_PUBLIC_MAS_URL=http://192.168.0.188:8001
NEXT_PUBLIC_MAS_API_URL=http://192.168.0.188:8001
NEXT_PUBLIC_MAS_WS_URL=ws://192.168.0.188:8001/ws
NEXT_PUBLIC_MAS_WS_ENABLED=true
NEXT_PUBLIC_MAS_SSE_URL=http://192.168.0.188:8001/sse
NEXT_PUBLIC_MAS_SSE_ENABLED=false

# -----------------------------------------------------------------------------
# MINDEX (Mycological Index Database)
# -----------------------------------------------------------------------------
MINDEX_API_URL=http://192.168.0.189:8000
MINDEX_API_KEY=
# Match the API key configured on MINDEX VM (API_KEYS / MINDEX_API_KEY env var).
# For local dev with MINDEX .env: MINDEX_API_KEY=dev-local-key
# For production: use same key as MINDEX VM's API_KEYS
NEXT_PUBLIC_MINDEX_URL=http://192.168.0.189:8000
NEXT_PUBLIC_MINDEX_API_URL=http://192.168.0.189:8000

# -----------------------------------------------------------------------------
# MycoBrain IoT
# -----------------------------------------------------------------------------
NEXT_PUBLIC_MYCOBRAIN_STREAM_URL=ws://localhost:8765/ws
MYCOBRAIN_API_URL=http://localhost:8765

# -----------------------------------------------------------------------------
# PersonaPlex Voice System
# -----------------------------------------------------------------------------
NEXT_PUBLIC_PERSONAPLEX_WS_URL=ws://localhost:8999/api/chat
NEXT_PUBLIC_PERSONAPLEX_BRIDGE_URL=http://localhost:8999
NEXT_PUBLIC_PERSONAPLEX_BRIDGE_WS_URL=ws://localhost:8999
ELEVENLABS_API_KEY=

# -----------------------------------------------------------------------------
# Payments (Stripe)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# -----------------------------------------------------------------------------
# Maps & Geospatial
# -----------------------------------------------------------------------------
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
MAPBOX_ACCESS_TOKEN=
AZURE_MAPS_KEY=

# -----------------------------------------------------------------------------
# External Data APIs
# -----------------------------------------------------------------------------
AISSTREAM_API_KEY=
EBIRD_API_KEY=
NEXT_PUBLIC_NEWS_API_KEY=
NEXT_PUBLIC_TMDB_API_KEY=

# -----------------------------------------------------------------------------
# Monitoring (Grafana)
# -----------------------------------------------------------------------------
GRAFANA_USER=admin
GRAFANA_PASSWORD=admin

# -----------------------------------------------------------------------------
# Notifications
# -----------------------------------------------------------------------------
SLACK_WEBHOOK=
ALERT_WEBHOOK_URL=

# -----------------------------------------------------------------------------
# GPU Services
# -----------------------------------------------------------------------------
NEXT_PUBLIC_USE_LOCAL_GPU=false
LOCAL_GPU_GATEWAY=http://localhost:7860

# Future: 4x RTX 4080 GPU cluster (16GB VRAM each, 64GB total)
# When deployed, point Ollama at the cluster and run Nemotron 70B locally:
# OLLAMA_BASE_URL=http://<gpu-cluster-ip>:11434
# OLLAMA_MODEL=nemotron:70b
# GPU_CLUSTER_URL=http://<gpu-cluster-ip>:8000
# GPU_CLUSTER_NODES=4
