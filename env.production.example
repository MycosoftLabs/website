# =============================================================================
# Mycosoft Production Environment — mycosoft.com
# =============================================================================
# Copy to .env on the PRODUCTION VM and fill in real values.
# This file MUST contain all secrets needed for the live site.
#
# SECURITY: Never commit .env to git. Only commit this .example file.
# =============================================================================

# =============================================================================
# CLOUDFLARE TUNNEL (REQUIRED — this is how users reach the site)
# =============================================================================
# Get from: Cloudflare Zero Trust > Access > Tunnels > [your tunnel] > Token
CLOUDFLARE_TUNNEL_TOKEN=
# For cache purge after deploys
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ZONE_ID=

# =============================================================================
# DATABASE (REQUIRED)
# =============================================================================
POSTGRES_USER=mycosoft
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD_HERE
POSTGRES_DB=mycosoft
DATABASE_URL=postgresql://mycosoft:CHANGE_ME_STRONG_PASSWORD_HERE@postgres:5432/mycosoft

# =============================================================================
# SUPABASE (REQUIRED for auth & data)
# =============================================================================
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# =============================================================================
# AUTH (REQUIRED)
# =============================================================================
NEXTAUTH_URL=https://mycosoft.com
NEXTAUTH_SECRET=GENERATE_WITH_openssl_rand_base64_32

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# GitHub OAuth
GITHUB_ID=
GITHUB_SECRET=

# =============================================================================
# AI PROVIDERS — At least ONE must be valid for MYCA to work
# =============================================================================
# Groq is cheapest and fastest — recommended as primary
GROQ_API_KEY=

# Anthropic Claude — highest quality responses
ANTHROPIC_API_KEY=

# OpenAI GPT-4
OPENAI_API_KEY=

# Google Gemini
GOOGLE_AI_API_KEY=

# xAI Grok
XAI_API_KEY=

# ElevenLabs (voice — optional)
ELEVENLABS_API_KEY=

# =============================================================================
# CACHE (Redis)
# =============================================================================
REDIS_URL=redis://redis:6379
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD

# =============================================================================
# LOCAL LLM (Ollama — runs in-stack, zero cost, always available)
# =============================================================================
# The Ollama container handles this automatically.
# After first deploy: docker exec mycosoft-ollama ollama pull llama3.3
OLLAMA_MODEL=llama3.3

# =============================================================================
# MAS / MINDEX (cross-VM services)
# =============================================================================
# These are on your LAN. If unreachable, MYCA falls back to cloud LLMs.
MAS_API_URL=http://${MAS_VM_HOST:-localhost}:8001
MINDEX_API_URL=http://${MINDEX_VM_HOST:-localhost}:8000
NEXT_PUBLIC_MAS_API_URL=http://${MAS_VM_HOST:-localhost}:8001

# =============================================================================
# PAYMENTS (Stripe)
# =============================================================================
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# =============================================================================
# PUBLIC URLS
# =============================================================================
NEXT_PUBLIC_BASE_URL=https://mycosoft.com
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# =============================================================================
# N8N WORKFLOW AUTOMATION
# =============================================================================
N8N_USER=admin
N8N_PASSWORD=CHANGE_ME_N8N_PASSWORD

# =============================================================================
# MONITORING
# =============================================================================
GRAFANA_USER=admin
GRAFANA_PASSWORD=CHANGE_ME_GRAFANA_PASSWORD
