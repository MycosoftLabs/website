# Dependencies (explicit patterns — Windows Docker can still send huge contexts otherwise)
node_modules
**/node_modules
.pnpm-store

# Build outputs
.next
out
dist
build

# Development files
.git
.gitignore
*.md
LICENSE

# IDE / local tooling (can be hundreds of MB — never needed in the image)
.cursor
**/.cursor
.vscode
.idea
*.swp
*.swo

# Environment files
.env
.env.*
!.env.example

# Debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Testing
coverage
.nyc_output
playwright-report
test-results
.turbo
.cache

# Misc
.DS_Store
Thumbs.db
*.log

# Heavy components to segregate
services
videos
screenshots
tests
e2e
python-services
public/assets

