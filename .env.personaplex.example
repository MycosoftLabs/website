# PersonaPlex Voice System Configuration
# Created: February 11, 2026
#
# Choose configuration based on your deployment environment:
# - Local Development (GPU on dev machine)
# - MAS VM Deployment (GPU on 192.168.0.188)
# - Remote GPU Service (cloud GPU provider)

# =============================================================================
# OPTION 1: LOCAL DEVELOPMENT (Default - GPU on Dev Machine)
# =============================================================================
# Use when running PersonaPlex locally with RTX 5090
# Start with: python scripts/start_myca_voice.py

NEXT_PUBLIC_PERSONAPLEX_WS_URL=ws://localhost:8999/api/chat
PERSONAPLEX_BRIDGE_URL=http://localhost:8999
MOSHI_SERVER_URL=ws://localhost:8998

# =============================================================================
# OPTION 2: MAS VM DEPLOYMENT (If GPU available on MAS VM)
# =============================================================================
# Use when PersonaPlex is deployed to MAS VM (192.168.0.188)
# Uncomment these to enable:

# NEXT_PUBLIC_PERSONAPLEX_WS_URL=ws://192.168.0.188:8999/api/chat
# PERSONAPLEX_BRIDGE_URL=http://192.168.0.188:8999
# MOSHI_SERVER_URL=ws://192.168.0.188:8998

# =============================================================================
# OPTION 3: SANDBOX VM (If GPU becomes available)
# =============================================================================
# Use when PersonaPlex is deployed to Sandbox VM (192.168.0.187)
# Currently NOT AVAILABLE - Sandbox VM has no GPU
# Uncomment these if GPU added to Sandbox:

# NEXT_PUBLIC_PERSONAPLEX_WS_URL=ws://192.168.0.187:8999/api/chat
# PERSONAPLEX_BRIDGE_URL=http://192.168.0.187:8999
# MOSHI_SERVER_URL=ws://192.168.0.187:8998

# =============================================================================
# OPTION 4: PRODUCTION with CLOUDFLARE (WSS for HTTPS sites)
# =============================================================================
# Use when PersonaPlex is proxied through Cloudflare
# Requires Cloudflare WebSocket proxy configuration

# NEXT_PUBLIC_PERSONAPLEX_WS_URL=wss://mycosoft.com/voice/ws
# PERSONAPLEX_BRIDGE_URL=https://mycosoft.com/voice
# MOSHI_SERVER_URL=wss://mycosoft.com/voice/moshi

# =============================================================================
# OPTION 5: REMOTE GPU SERVICE (RunPod, Lambda Labs, etc)
# =============================================================================
# Use when PersonaPlex runs on cloud GPU provider
# Replace with your actual remote GPU endpoint

# NEXT_PUBLIC_PERSONAPLEX_WS_URL=wss://your-gpu-instance.runpod.io/api/chat
# PERSONAPLEX_BRIDGE_URL=https://your-gpu-instance.runpod.io
# MOSHI_SERVER_URL=wss://your-gpu-instance.runpod.io/moshi

# =============================================================================
# MAS ORCHESTRATOR (Required for all PersonaPlex deployments)
# =============================================================================
# PersonaPlex Bridge connects to MAS for consciousness/memory

MAS_ORCHESTRATOR_URL=http://192.168.0.188:8001
NEXT_PUBLIC_MAS_URL=http://192.168.0.188:8001

# =============================================================================
# FEATURE FLAGS
# =============================================================================

# Enable/disable voice features on website
NEXT_PUBLIC_VOICE_ENABLED=true

# Enable Web Speech API fallback when PersonaPlex unavailable
NEXT_PUBLIC_WEB_SPEECH_FALLBACK=true

# Show voice debugging info in console
NEXT_PUBLIC_VOICE_DEBUG=false

# =============================================================================
# DEPLOYMENT VERIFICATION
# =============================================================================
# To verify PersonaPlex is working:
#
# 1. Check Moshi health:
#    curl http://localhost:8998/health
#
# 2. Check Bridge health:
#    curl http://localhost:8999/health
#
# 3. Check MAS Orchestrator:
#    curl http://192.168.0.188:8001/health
#
# 4. Test voice on website:
#    http://localhost:3010/test-voice
