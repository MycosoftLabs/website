# Production VM deploy secrets — copy to /opt/mycosoft/deploy.env (chmod 600).
# Used by scripts/blue-green-deploy.sh for automatic Cloudflare cache purge.
# Do NOT commit deploy.env. Source values from website/.credentials.local or GitHub
# Actions secrets CLOUDFLARE_ZONE_ID and CLOUDFLARE_API_TOKEN.
#
# Install: scripts/install-vm-deploy-env.sh (from a machine with .credentials.local)

CF_ZONE_ID=
CF_API_TOKEN=

# Aliases also accepted if you prefer CLOUDFLARE_* names:
# CLOUDFLARE_ZONE_ID=
# CLOUDFLARE_API_TOKEN=
